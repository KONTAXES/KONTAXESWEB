# Brevo (Sendinblue) – envío automático de correo con PDF adjunto
# Crea una cuenta gratis en https://brevo.com (300 emails/día gratis)
# Ve a Settings > API Keys > Generate a new API key
VITE_BREVO_API_KEY=your_brevo_api_key_here

# Correo remitente verificado en Brevo (debe estar verificado en tu cuenta)
# Si tu dominio kontaxes.com está verificado en Brevo puedes usar info@kontaxes.com
VITE_BREVO_SENDER=info@kontaxes.com
